<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="olist.sqlite" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2089"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="customers" custom_title="0" dock_id="1" table="4,9:maincustomers"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011300ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">SELECT count(*)
FROM orders;

SELECT *
FROM products
WHERE product_category_name IS NULL;

PRAGMA table_info(customers);
select count(*) FROM products;

-- product_category_name has 610 rows that is null  
SELECT *
FROM products
WHERE product_category_name IS NULL;

SELECT DISTINCT *
FROM customers;
SELECT LOWER(customer_city)
FROM customers;

-- Dataset Overview
SELECT COUNT(*) FROM orders;
SELECT COUNT(*) FROM customers;
SELECT COUNT(*) FROM order_items;
SELECT COUNT(*) FROM products;

--Order Status Distribution

SELECT order_status, COUNT(*)
FROM orders
GROUP BY order_status;

--Monthly Order Trend
SELECT 
strftime('%Y-%m', order_purchase_timestamp) AS month,
COUNT(*) AS total_orders
FROM orders
GROUP BY month
ORDER BY month;

-- Customer Geographic Distribution
SELECT 
c.customer_state,
COUNT(o.order_id) AS total_orders
FROM orders o
JOIN customers c 
ON o.customer_id = c.customer_id
GROUP BY c.customer_state
ORDER BY total_orders DESC;

-- how many customer are in each city and state
select customer_city, customer_state, count(*) as city_count
from customers
group by customer_city, customer_state
order by count(*) desc;

-- finding out the number of orders placed each day
select date(order_purchase_timestamp) AS order_purchase_date, count(*) as total_orders
from orders
group by date(order_purchase_timestamp)
order by count(*) DESC;

--  Payment Method Distribution
SELECT 
payment_type,
COUNT(*) AS total_payments
FROM order_payments
GROUP BY payment_type
ORDER BY total_payments DESC;
-- Customer Satisfaction
SELECT 
review_score,
COUNT(*) AS total_reviews
FROM order_reviews
GROUP BY review_score
ORDER BY review_score DESC;
-- found that there are duplicated VALUES
select p.product_id, p.product_category_name,o.order_id,o.order_item_id, o.*
from products p
inner join order_items o ON p.product_id = o.product_id;

---3. Popular categories for product (some project might exist, but never sold)
SELECT 
t.product_category_name_english,
COUNT(o.order_id) AS total_orders
FROM products p
LEFT JOIN order_items o
ON p.product_id = o.product_id
LEFT JOIN product_category_name_translation t
ON p.product_category_name = t.product_category_name
GROUP BY t.product_category_name_english
ORDER BY total_orders DESC;

-- 4. since we have order delivery carrier date, order delivered customer , order estimated delivery
-- we have the estimated delivery date and actual delivery date. So we can find how close the estimate and actual are, if they have gotten better or worse over time. show the different for each month
-- Select orders that were delivered. Because undelivered orders have NULL delivery dates.
-- tacking delivery delays, customer satisfaction, logistics efficiency
-- Are deliveries getting more accurate over time?
SELECT 
order_id,
order_status,
strftime('%Y-%m', order_purchase_timestamp) AS order_month,
order_delivered_customer_date,
order_estimated_delivery_date,
julianday(order_delivered_customer_date) 
- julianday(order_estimated_delivery_date) AS date_diff
FROM orders
WHERE order_status = 'delivered';

-- 5. because we said estimated delivery date - actual delivery date, this is the number of days that the estimate is after the acctual.
-- So the number of days that the actual delivery date was earlier than the estimated delivery date
SELECT 
strftime('%Y-%m', order_purchase_timestamp) AS order_month,
AVG(julianday(order_estimated_delivery_date) 
- julianday(order_delivered_customer_date)) AS date_diff
FROM orders
WHERE order_status = 'delivered'
group by order_month;

-- checking both null
select * from orders
where order_status = 'delivered'
and (order_estimated_delivery_date is NULL OR order_delivered_customer_date is NULL);

-- 6. orders that took longer than normal
-- orders that have a different between the expected and actual delivery date which is higher than the average for the month
  
 

SELECT *
FROM (
    SELECT
        order_id,
        order_year,
        order_month,
        actual_delivery_date,
        estimated_delivery_date,
        julianday(estimated_delivery_date) - julianday(actual_delivery_date) AS date_diff,
        AVG(julianday(estimated_delivery_date) - julianday(actual_delivery_date))
            OVER (PARTITION BY order_year, order_month) AS avg_month_diff
    FROM (
        SELECT
            order_id,
            strftime('%Y', order_purchase_timestamp) AS order_year,
            strftime('%m', order_purchase_timestamp) AS order_month,
            order_delivered_customer_date AS actual_delivery_date,
            order_estimated_delivery_date AS estimated_delivery_date
        FROM orders
        WHERE order_status = 'delivered'
        AND order_delivered_customer_date IS NOT NULL
    ) s
) t
WHERE date_diff &lt; avg_month_diff;

-- 7. Delivery delay by state
CREATE VIEW delayed_state as 
SELECT 
c.customer_state,
ROUND(
AVG(
julianday(o.order_delivered_customer_date) -
julianday(o.order_estimated_delivery_date)
),2) AS avg_delay
FROM orders o
JOIN customers c
ON o.customer_id = c.customer_id
WHERE o.order_status = 'delivered'
GROUP BY c.customer_state
ORDER BY avg_delay DESC;

select * from delayed_state;

-- Are certain categories associated with lower review scores?
SELECT 
t.product_category_name_english,
AVG(r.review_score) AS avg_review_score
FROM order_items oi
JOIN products p 
ON oi.product_id = p.product_id
JOIN product_category_name_translation t
ON p.product_category_name = t.product_category_name
JOIN order_reviews r
ON oi.order_id = r.order_id
GROUP BY t.product_category_name_english
ORDER BY avg_review_score ASC;

--Which products may have quality issues based on customer reviews?
SELECT 
p.product_id,
AVG(r.review_score) AS avg_review_score,
COUNT(*) AS review_count
FROM order_items oi
JOIN products p 
ON oi.product_id = p.product_id
JOIN order_reviews r 
ON oi.order_id = r.order_id
GROUP BY p.product_id
HAVING review_count &gt; 10
ORDER BY avg_review_score ASC;

-- Does delivery performance affect customer review scores?
SELECT
r.review_score,
AVG(
julianday(o.order_delivered_customer_date) -
julianday(o.order_estimated_delivery_date)
) AS avg_delay
FROM orders o
JOIN order_reviews r
ON o.order_id = r.order_id
WHERE o.order_status = 'delivered'
GROUP BY r.review_score
ORDER BY r.review_score;

-- find the product that were never been purchase
SELECT 
p.product_id,
p.product_category_name
FROM products p
LEFT JOIN order_items oi
ON p.product_id = oi.product_id
WHERE oi.product_id IS NULL;
-- Top Customers by Total Spending
SELECT 
c.customer_id,
c.customer_state,
SUM(op.payment_value) AS total_spent,
RANK() OVER (ORDER BY SUM(op.payment_value) DESC) AS spending_rank
FROM customers c
LEFT JOIN orders o
ON c.customer_id = o.customer_id
LEFT JOIN order_payments op
ON o.order_id = op.order_id
GROUP BY c.customer_id, c.customer_state
ORDER BY total_spent DESC
LIMIT 10;
-- top product per category
SELECT *
FROM (
    SELECT
    t.product_category_name_english,
    p.product_id,
    COUNT(oi.order_id) AS total_orders,
    RANK() OVER (
        PARTITION BY t.product_category_name_english
        ORDER BY COUNT(oi.order_id) DESC
    ) AS category_rank
    FROM products p
    LEFT JOIN order_items oi
    ON p.product_id = oi.product_id
    LEFT JOIN product_category_name_translation t
    ON p.product_category_name = t.product_category_name
    GROUP BY t.product_category_name_english, p.product_id
) ranked_products
WHERE category_rank &lt;= 3;

-- delayed date
WITH delivery_analysis AS (
    SELECT
    order_id,
    strftime('%Y-%m', order_purchase_timestamp) AS order_month,
    julianday(order_delivered_customer_date) -
    julianday(order_estimated_delivery_date) AS delivery_diff
    FROM orders
    WHERE order_status = 'delivered'
)
SELECT
order_month,
AVG(delivery_diff) AS avg_delivery_delay
FROM delivery_analysis
GROUP BY order_month
ORDER BY order_month;
-- How many orders were delivered late vs early?
WITH delivery_analysis AS (
    SELECT
    order_id,
    strftime('%Y-%m', order_purchase_timestamp) AS order_month,
    julianday(order_delivered_customer_date) -
    julianday(order_estimated_delivery_date) AS delivery_diff
    FROM orders
    WHERE order_status = 'delivered'
)
SELECT
CASE
WHEN delivery_diff &gt; 0 THEN 'Late Delivery'
WHEN delivery_diff &lt; 0 THEN 'Early Delivery'
ELSE 'On Time'
END AS delivery_status,
COUNT(*) AS total_orders
FROM delivery_analysis
GROUP BY delivery_status;
-------------------------------------------------------------------------------------------------
CREATE VIEW order_month_view AS
SELECT
    order_id,
    customer_id,
    order_status,
    order_purchase_timestamp,
    strftime('%Y-%m', order_purchase_timestamp) AS order_month
FROM orders;

select * from order_month_view;</sql><current_tab id="0"/></tab_sql></sqlb_project>
